# ─────────────────────────────────────────────────────────────
# 1. Copy this file to a new file named exactly:  .env
# 2. Paste your real Anthropic API key after the = sign below.
# 3. Get a key at:  https://console.anthropic.com/
#
# Your real .env file is ignored by Git (see .gitignore),
# so your secret key will NOT be uploaded to GitHub.
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here
